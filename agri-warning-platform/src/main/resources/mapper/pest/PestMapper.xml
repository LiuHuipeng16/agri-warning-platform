<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zhku.agriwarningplatform.module.pest.mapper.PestMapper">

    <!-- =========================
         ResultMap
    ========================== -->
    <resultMap id="PestDOResultMap" type="com.zhku.agriwarningplatform.module.pest.mapper.dataobject.PestDO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
        <result property="description" column="description"/>
        <result property="symptoms" column="symptoms"/>
        <result property="cause" column="cause"/>
        <result property="prevention" column="prevention"/>
        <result property="riskLevel" column="risk_level"/>
        <result property="season" column="season"/>
        <result property="deleteFlag" column="delete_flag"/>
        <result property="gmtCreate" column="gmt_create"/>
        <result property="gmtModified" column="gmt_modified"/>
    </resultMap>

    <resultMap id="PestPageItemDTOResultMap" type="com.zhku.agriwarningplatform.module.pest.service.dto.PestPageItemDTO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
        <result property="riskLevel" column="risk_level"/>
        <result property="season" column="season"/>
        <result property="description" column="description"/>
    </resultMap>

    <resultMap id="PestOptionDTOResultMap" type="com.zhku.agriwarningplatform.module.pest.service.dto.PestOptionDTO">
        <result property="label" column="label"/>
        <result property="value" column="value"/>
    </resultMap>

    <!-- =========================
         SQL Segment
    ========================== -->
    <sql id="Base_Column_List">
        id,
        name,
        type,
        description,
        symptoms,
        cause,
        prevention,
        risk_level,
        season,
        delete_flag,
        gmt_create,
        gmt_modified
    </sql>

    <sql id="Page_Where_Condition">
        p.delete_flag = 0
        <if test="name != null and name != ''">
            AND p.name LIKE CONCAT('%', #{name}, '%')
        </if>
        <if test="type != null and type != ''">
            AND p.type = #{type}
        </if>
        <if test="riskLevel != null and riskLevel != ''">
            AND p.risk_level = #{riskLevel}
        </if>
        <if test="season != null and season != ''">
            AND p.season = #{season}
        </if>
        <if test="cropId != null">
            AND EXISTS (
            SELECT 1
            FROM crop_pest_rel cpr
            WHERE cpr.pest_id = p.id
            AND cpr.crop_id = #{cropId}
            AND cpr.delete_flag = 0
            )
        </if>
    </sql>

    <!-- =========================
         insert
    ========================== -->
    <insert id="insert">
        INSERT INTO pest (
            id,
            name,
            type,
            description,
            symptoms,
            cause,
            prevention,
            risk_level,
            season,
            delete_flag
        ) VALUES (
                     #{id},
                     #{name},
                     #{type},
                     #{description},
                     #{symptoms},
                     #{cause},
                     #{prevention},
                     #{riskLevel},
                     #{season},
                     #{deleteFlag}
                 )
    </insert>

    <!-- =========================
         update
    ========================== -->
    <update id="updateById">
        UPDATE pest
        SET
            name = #{name},
            type = #{type},
            description = #{description},
            symptoms = #{symptoms},
            cause = #{cause},
            prevention = #{prevention},
            risk_level = #{riskLevel},
            season = #{season}
        WHERE id = #{id}
          AND delete_flag = 0
    </update>

    <update id="logicDeleteById">
        UPDATE pest
        SET delete_flag = 1
        WHERE id = #{id}
          AND delete_flag = 0
    </update>

    <!-- =========================
         select single
    ========================== -->
    <select id="selectById" resultMap="PestDOResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM pest
        WHERE id = #{id}
        AND delete_flag = 0
        LIMIT 1
    </select>

    <select id="selectByIdIncludingDeleted" resultMap="PestDOResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM pest
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="selectByName" resultMap="PestDOResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM pest
        WHERE name = #{name}
        AND delete_flag = 0
        LIMIT 1
    </select>

    <select id="selectByNameExcludeId" resultMap="PestDOResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM pest
        WHERE name = #{name}
        AND id != #{excludeId}
        AND delete_flag = 0
        LIMIT 1
    </select>

    <!-- =========================
         page
    ========================== -->
    <select id="countPage" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM pest p
        WHERE
        <include refid="Page_Where_Condition"/>
    </select>

    <select id="selectPage" resultMap="PestPageItemDTOResultMap">
        SELECT
        p.id,
        p.name,
        p.type,
        p.risk_level,
        p.season,
        p.description
        FROM pest p
        WHERE
        <include refid="Page_Where_Condition"/>
        ORDER BY p.gmt_create DESC, p.id DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- =========================
         options
    ========================== -->
    <select id="selectOptions" resultMap="PestOptionDTOResultMap">
        SELECT
            name AS label,
            id AS value
        FROM pest
        WHERE delete_flag = 0
        ORDER BY gmt_create DESC, id DESC
    </select>

</mapper>